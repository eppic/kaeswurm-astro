---
import { Image } from 'astro:assets';

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Ticker from "../components/Ticker.astro";
import MailSection from "../components/MailSection.astro";

import img_hero from "../../public/img/ausb/hero.webp";

const ticker = [
    "Die Kurse im Frühling 2026 sind bereits ausgebucht.",
    "Für die Termine im Herbst 2026 sind noch freie Plätze verfügbar.",
    "Die Kurse im Frühling 2026 sind bereits ausgebucht.",
    "Für die Termine im Herbst 2026 sind noch freie Plätze verfügbar.",
]

import alm_1 from "../../public/img/ausb/alm/alm_1.webp";
import alm_2 from "../../public/img/ausb/alm/alm_2.webp";
import alm_3 from "../../public/img/ausb/alm/alm_3.webp";
import alm_4 from "../../public/img/ausb/alm/alm_4.webp";
import alm_5 from "../../public/img/ausb/alm/alm_5.webp";
import alm_6 from "../../public/img/ausb/alm/alm_6.webp";

import gal_1 from "../../public/img/ausb/gal/gal_1.webp";
import gal_2 from "../../public/img/ausb/gal/gal_2.webp";
import gal_3 from "../../public/img/ausb/gal/gal_3.webp";
import gal_4 from "../../public/img/ausb/gal/gal_4.webp";
import gal_5 from "../../public/img/ausb/gal/gal_5.webp";

---

<Layout>
    <main>
        <Hero img={img_hero} text="Ausbildung">
            <div class="disclaimer">
                <h2 class="desktop typo-24">Unsere nächsten Termine:</h2>
                <h2 class="mobile typo-24">Unsere nächsten <br>Termine:</h2>
                <ul>
                    <li>05. & 06. September 2026</li>
                    <li>19. & 20. September 2026</li>
                </ul>
                <p><span>Die Ausbildung findet an den genannten Wochenenden statt.</span></p>
                <img src="/svg/warning.svg" alt="warning icon">
            </div>
        </Hero>

        <Ticker color={'var(--kw-green)'} ticker={ticker} speed="40s"/>
    
        <div id="content">

            <section class="summary section_def">
                <h2 class="typo-36">Line-Dance-Trainer*innen-Ausbildung</h2>
                <p class="gray">nach Astrid Kaeswurm</p>

                <p class="gray">Eine zeitgemäße Ausbildung für alle, die Line Dance professioneller unterrichten möchten - praxisnah, strukturiert und stilübergreifend (Country, Modern & Mixed). Der Lehrgang wurde von einer Line-Dance-Trainerin für Line Dancer entwickelt und orientiert sich an den Erfahrungen aus dem Unterricht mit ganz unterschiedlichen Gruppen.
                    <br> Du erhältst fundierte didaktische und methodische Impulse, die dich dabei unterstützen, Gruppen sicher anzuleiten und deinen Unterricht abwechslungsreich zu gestalten. Neben Technik, Musikalität und Choreografie stehen auch Unterrichtsaufbau, Kommunikation und der Umgang mit verschiedenen Leistungsniveaus im Fokus.
                </p>
            </section>

            <section class="skills section_def">

                <h2 class="typo-36">Das lernst du</h2>

                <div class="skills-container">
                        
                    <div>
                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/compass.svg" alt="Didaktik">
                                <h3 class="typo-24">Didaktik & Unterricht</h3>
                            </div>
                            <div class="gray">
                                <ul>
                                    <li>Zielgruppen definieren und sinnvoll ansprechen</li>
                                    <li>Aufbau moderner Line-Dance-Unterrichtseinheiten</li>
                                    <li>Raumorientierung, Flächennutzung und Anpassung von Choreografien</li>
                                    <li>Auswahl und Analyse geeigneter Musik & Tänze</li>
                                </ul>
                            </div>
                        </div>

                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/clock.svg" alt="Ablauf">
                                <h3 class="typo-24">Ablauf & Umfang</h3>
                            </div>
                            <div class="gray">
                                <ul>
                                    <li><span>24 Stunden</span> Gesamtumfang (32 Lerneinheiten inkl. Praxis- & Übungsstunden)</li>
                                    <li>Durchführung an zwei aufeinander aufbauenden Wochenenden</li>
                                    <li>Die Wochenenden sind <span>nicht</span> einzeln buchbar</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/gears.svg" alt="Technik">
                                <h3 class="typo-24">Technik & Körperarbeit</h3>
                            </div>
                            <div class="gray">
                                <ul>
                                    <li>Grundhaltung und saubere Bewegung</li>
                                    <li>Fußpositionen und Gewichtsverlagerung</li>
                                    <li>Passende Tänze für unterschiedliche Levels</li>
                                </ul>
                            </div>
                        </div>

                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/pen.svg" alt="Prüfung">
                                <h3 class="typo-24">Prüfung & Abschluss</h3>
                            </div>
                            <div class="gray">
                                <p>Die Ausbildung schließt mit einer dreiteiligen Prüfung ab:</p>
                                <ul>
                                    <li><span>schriftlich</span></li>
                                    <li><span>mündlich</span></li>
                                    <li><span>praktische Lehrprobe (Kolloquium)</span></li>
                                </ul>
                                <p>Nach erfolgreichem Abschluss erhältst du ein Zertifikat. Regelmäßige Weiterbildung wird empfohlen.</p>
                            </div>
                        </div>

                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/bell.svg" alt="Hinweis">
                                <h3 class="typo-24">Hinweis</h3>
                            </div>
                            <div class="gray">
                                <p>Diese Trainer:innen-Ausbildung ist eine <span>private Qualifikation</span> und wird <span>nicht von offiziellen Sportverbänden anerkannt.</span></p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/check.svg" alt="Praxis">
                                <h3 class="typo-24">Praxis</h3>
                            </div>
                            <div class="gray">
                                <ul>
                                    <li>Schrittfolgen, Tanzarten und Variationen</li>
                                    <li>Anwendung des Gelernten im realen Unterrichtssetting</li>
                                </ul>
                            </div>
                        </div>

                        <div class="skills-item">
                            <div>
                                <img src="/svg/ausb/euro.svg" alt="Kosten">
                                <h3 class="typo-24">Kosten</h3>
                            </div>
                            <div class="gray">
                                <p>Die Kursgebühr beträgt <span>350 €</span>.</p>
                                <p>Hinzu kommen <span>50 € Prüfgebühren</span>, falls der Teilnehmer an der Prüfung teilnehmen möchte.</p>
                                <p>Die Entscheidung zur Prüfung kann am Tag der Prüfung getroffen werden; die Gebühr fällt nur dann an.</p>
                                <p><span>Insgesamt würden somit 400 € anfallen.</span></p>
                                <p>In den Kursgebühren enthalten sind:</p>
                                <ul>
                                    <li>Alle Unterrichtsmaterialien</li>
                                    <li>Das Line-Dance-Buch</li>
                                    <li>Getränke während der Schulung</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

            <section class="faq section_def">
                <h2 class="typo-36">Häufig gestellte<br>Fragen</h2>

                <div>
                    <div class="faq-item">
                        <h3 class="typo-24"><img src="/svg/circle.svg" alt="Circle">Brauche ich Vorkenntnisse oder Tanzerfahrung?</h3>
                        <p class="gray">Grundlegende Line-Dance-Erfahrung ist von Vorteil, aber keine formale Ausbildung oder Trainerlizenz erforderlich. Die Inhalte sind so aufgebaut, dass sowohl ambitionierte Tänzer:innen als auch bereits unterrichtende Personen davon profitieren.</p>
                    </div>
                    <div class="faq-item">
                        <h3 class="typo-24"><img src="/svg/hash.svg" alt="Hash">Ab welchem Alter kann ich an der Ausbildung teilnehmen?</h3>
                        <p class="gray">Die Line-Dance-Trainer*innen-Ausbildung richtet sich an Teilnehmer:innen ab 18 Jahren. Voraussetzung ist die Freude am Tanzen und der Wunsch, Line Dance professioneller unterrichten zu können - unabhängig vom bisherigen Werdegang.</p>
                    </div>
                    <div class="faq-item">
                        <h3 class="typo-24"><img src="/svg/triangle.svg" alt="Triangle">Ist die Ausbildung offiziell anerkannt?</h3>
                        <p class="gray">Die Ausbildung ist eine private Qualifikation nach dem Buch Astrid Kaeswurm, von Anchor Step bis Weave und wird nicht von offiziellen Sportverbänden anerkannt. Sie vermittelt jedoch praxisnahe Kompetenzen, die für den professionellen Unterricht von Line Dance erforderlich sind.</p>
                    </div>
                </div>
            </section>

            <section class="gallery section_def">
                <h2 class="typo-36">Blicke hinter die Kulissen der Ausbildung</h3>
                <p>Hier siehst du viele Eindrücke aus den Ausbildungen der letzten Jahre: von den ersten Schritten in der Praxis bis zu besonderen Momenten hinter den Kulissen. Einige geprüfte TrainerInnen wurden nach ihrer Ausbildung sogar bereits als Line-Dance-Trainerinnen auf Kreuzfahrtschiffen gebucht.</p>

                <div class="images-container">
                    <div>
                        <div><Image class="gal_1" src={gal_1} alt="Person sitting in a chair"/></div>
                        <div><Image class="gal_2"src={gal_2} alt="Club Meeting in a big room"/></div>
                    </div>
                    <div>
                        <div><Image class="gal_3" src={gal_3} alt="Group Photo"/></div>
                        <div><Image class="gal_4" src={gal_4} alt="People line dancing"/></div>
                        <div><Image class="gal_5" src={gal_5} alt="People line dancing"/></div>
                    </div>     
                </div>

            </section>

            <section class="alm-wrapper">
                <div class="alm">
                    <div class="carousel">
                        <div class="slider">
                            <Image src={alm_1} alt="Images" />
                            <Image src={alm_2} alt="Images" />
                            <Image src={alm_3} alt="Images" />
                            <Image src={alm_4} alt="Images" />
                            <Image src={alm_5} alt="Images" />
                            <Image src={alm_6} alt="Images" />
                        </div>

                        <button class="prev">&#10094;</button>
                        <button class="next">&#10095;</button>

                        <div class="slider-nav"></div>
                    </div>

                    <div>
                        <h2 class="typo-36">Neubichler Alm</h2>
                        <p>Für unsere Ausbildung habe ich die idyllische Neubichler Alm im Salzburger Land ausgewählt - ein Ort, der Ruhe, Natur und Inspiration vereint. Hier kannst du dich ganz auf den Unterricht konzentrieren, in den Pausen wandern, durchatmen oder einfach die atemberaubende Bergkulisse genießen. Abends wird gemeinsam gegessen, getanzt und gelacht - denn Line Dance verbindet!</p>
                        <a href="https://maps.app.goo.gl/wjtHTf9QJ4hUsYaN8" target="_blank" rel="noopener noreferrer">auf Karte anzeigen</a>
                    </div>
                </div>
            </section>

            <MailSection href="mailto:astrid@kaeswurm.de?subject=Ausbildung">
                Jetzt schreiben
            </MailSection>

        </div>


    </main>
</Layout>



<style>

    .disclaimer {
        color: var(--base-white);
        background-color: var(--kw-green2);
        padding: var(--spacing-m);
        padding-bottom: var(--spacing-l);
        border-radius: var(--spacing-s);

        display: flex;
        flex-direction: column;
        gap: var(--spacing-s);

        position: relative;
        width: fit-content;

        ul {
            list-style-type: disc;
            list-style-position: inside;
            margin-left: var(--spacing-s);
        }

        span {
            font-weight: 600;
        }

        img {
            position: absolute;
            width: 2.75rem;
            right: var(--spacing-m);
            top: calc(var(--spacing-m) *0.75);
        }

    }

    .summary {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-s);
    }

    .skills {

        h2 {
            margin-bottom: var(--spacing-m);
        }

        .skills-container {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            grid-gap: var(--spacing-m);

            & > div {
                display: flex;
                flex-direction: column;
                gap: var(--spacing-m);
            }
        }

        .skills-item {
            background-color: var(--base-white);
            border-radius: var(--spacing-s);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            padding: var(--spacing-m);

            & div:first-child {
                display: flex;
                align-items: center;
                gap: var(--spacing-s);

                img {
                    width: 2rem;

                }

                margin-bottom: var(--spacing-m);
            }

            & div:last-child {
                ul {
                    list-style: disc;
                    list-style-position: inside;
                    margin-left: calc(var(--spacing-s)*0.5);
                }

                span {
                    font-weight: 600;
                }

                display: flex;
                flex-direction: column;
                gap: var(--spacing-s);
            }

        }
    }

    .faq {
        display: flex;
        gap: var(--spacing-xl);

        h2 {
            min-width: fit-content;
            line-height: 120%;
        }

        & > div {
            display: flex;
            flex-direction: column;
            gap: var(--spacing-s);
        }

        .faq-item {
            background-color: var(--kw-green-light);
            border-radius: var(--spacing-s);
            padding: calc(var(--spacing-m) * 0.75);

            h3 {
                display: flex;
                gap: var(--spacing-s);
                margin-bottom: var(--spacing-s);
            }
        }

    }

    .gallery {

        display: flex;
        flex-direction: column;
        gap: var(--spacing-m);
        margin-bottom: var(--spacing-l);

        .images-container {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            grid-gap: var(--spacing-s);

            & > div {
                display: flex;
                flex-direction: column;
                gap: var(--spacing-s);


            }
            
        }

        img {
            object-fit: cover;
            border-radius: var(--spacing-s);
        }

        .gal_1 {
            height: 24rem;
        }
        .gal_2 {
            height: 21rem;
        }
        .gal_3, .gal_5 {
            height: 16rem;
        }
        .gal_4 {
            height: 18rem;
        }

        @media (max-width: 920px) {
            .gal_1 {
                height: 12rem;
            }
            .gal_2 {
                height: 10.5rem;
            }
            .gal_3, .gal_5 {
                height: 8rem;
            }
            .gal_4 {
                height: 9rem;
            }

            .images-container {
                
                grid-gap: calc(var(--spacing-s) * 0.5);

                div {
                    gap: calc(var(--spacing-s) * 0.5);
                }
            }
        }

    }

    .alm-wrapper {
        background-color: var(--base-black);
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .alm {
        max-width: 1200px;
        
        background-color: var(--base-black);
        color: var(--base-white);
        display: flex;

        .carousel {
        position: relative;
        width: 100%;
        max-width: 800px;
        margin: auto;
        overflow: hidden;
        }

        .slider {
        display: flex;
        transition: transform 0.5s ease-in-out;

        display: flex;
        transition: transform 0.5s ease-in-out;
        touch-action: pan-y;
        }


        .slider img {
        width: 100%;
        flex-shrink: 0;
        object-fit: cover;
        }

        /* Pfeile */
        .prev, .next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        color: var(--kw-yellow);
        border: none;
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-size: 1.5rem;
        z-index: 10;
        }

        .prev { left: 10px; }
        .next { right: 10px; }

        /* Dots */
        .slider-nav {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        position: absolute;
        bottom: 15px;
        left: 50%;
        transform: translateX(-50%);
        }

        .slider-nav button {
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        border: none;
        background: var(--base-white);
        cursor: pointer;
        }

        .slider-nav button.active {
        background: var(--kw-yellow);
        }

     
        & > div:last-child {
            flex: 0 0 36%;

            padding-left: var(--spacing-l);
            padding-right: var(--spacing-m);

            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: var(--spacing-s);

            h2 {
                color: var(--kw-yellow);
            }

            a {
                color: var(--kw-yellow);
                text-align: end;
                text-decoration: underline;
                padding-right: var(--spacing-m);
            }
        }
    }

    @media (max-width: 900px) {
        .skills {
            
            .skills-container {
                display: flex;
                flex-direction: column;

            }
        }
    }
    
    @media (max-width: 945px) {
        .faq {
            flex-direction: column;
            gap: var(--spacing-l);
        }

        .alm-wrapper {

            .alm {

                .slider-wrapper {
                    flex: unset;
                }
                
                & > div:last-child {
                    flex: unset;

                    padding: var(--spacing-m);
                }
                flex-direction: column;
            }
        }
    }

    @media (max-width: 450px) {
        .mobile {
            display: block;
        }

        .desktop {
            display: none;
        }
    }

    @media (max-width: 345px) {
        .disclaimer {

            padding: var(--spacing-s);
        
            img {
                display: none;
            }
        }
    }

    

</style>


<script is:inline>
  const slider = document.querySelector(".slider");
  const slides = document.querySelectorAll(".slider img");
  const prevBtn = document.querySelector(".prev");
  const nextBtn = document.querySelector(".next");
  const nav = document.querySelector(".slider-nav");

  let current = 0;
  let startX = 0;
  let isDragging = false;
  const autoplayDelay = 4000;

  // -----------------------
  // DOTS ERZEUGEN
  // -----------------------
  slides.forEach((_, index) => {
    const dot = document.createElement("button");
    if (index === 0) dot.classList.add("active");

    dot.addEventListener("click", () => {
      current = index;
      updateSlider();
      resetAutoplay();
    });

    nav.appendChild(dot);
  });

  const dots = document.querySelectorAll(".slider-nav button");

  function updateSlider() {
    slider.style.transform = `translateX(-${current * 100}%)`;

    dots.forEach(dot => dot.classList.remove("active"));
    dots[current].classList.add("active");
  }

  function nextSlide() {
    current = (current + 1) % slides.length;
    updateSlider();
  }

  function prevSlide() {
    current = (current - 1 + slides.length) % slides.length;
    updateSlider();
  }

  nextBtn.addEventListener("click", () => {
    nextSlide();
    resetAutoplay();
  });

  prevBtn.addEventListener("click", () => {
    prevSlide();
    resetAutoplay();
  });

  // -----------------------
  // AUTOPLAY
  // -----------------------
  let autoplay = setInterval(nextSlide, autoplayDelay);

  function resetAutoplay() {
    clearInterval(autoplay);
    autoplay = setInterval(nextSlide, autoplayDelay);
  }

  // -----------------------
  // MOBILE SWIPE
  // -----------------------
  slider.addEventListener("touchstart", (e) => {
    startX = e.touches[0].clientX;
    isDragging = true;
  });

  slider.addEventListener("touchend", (e) => {
    if (!isDragging) return;

    const endX = e.changedTouches[0].clientX;
    const diff = startX - endX;

    if (diff > 50) {
      nextSlide();
    } else if (diff < -50) {
      prevSlide();
    }

    resetAutoplay();
    isDragging = false;
  });
</script>
